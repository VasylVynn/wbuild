# ── Vitryna environment ──────────────────────────────────────────────────
# Copy this file to .env.local and put REAL values there. .env.local is
# gitignored — never commit real keys. After editing .env.local, restart
# `npm run dev` (env is read at server start).

# Local dev root domain (tenants = *.lvh.me). Production: vitryna.com.ua
NEXT_PUBLIC_ROOT_DOMAIN=lvh.me:3000

# ── Supabase ──  Dashboard → Project Settings → API Keys
# New 2025 key format: publishable (public, browser-safe) + secret (server-only).
# Legacy JWT keys (anon / service_role) also work if your project shows them.
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=          # sb_publishable_...  (public)
SUPABASE_SERVICE_ROLE_KEY=                      # sb_secret_...  OR legacy service_role JWT — SERVER-ONLY, bypasses RLS

# ── Anthropic ──  console.anthropic.com → Settings → API keys
# Needed for Phase 2 (generation) and Phase 3 (agent-chat). Server-only.
ANTHROPIC_API_KEY=
